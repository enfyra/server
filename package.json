{
  "name": "enfyra-server",
  "version": "1.7.5",
  "description": "Dynamic backend platform that auto-generates REST and GraphQL APIs from database schemas",
  "author": "dothinh115 <dothinh115@gmail.com>",
  "private": false,
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "generate:mongo-fold": "node ./node_modules/ts-node/dist/bin.js scripts/generate-mongo-fold-text-search.ts",
    "build": "node ./node_modules/@nestjs/cli/bin/nest.js build && yarn generate:mongo-fold && cp -r data dist/",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "NODE_OPTIONS=\"--no-node-snapshot${NODE_OPTIONS:+ $NODE_OPTIONS}\" node ./node_modules/@nestjs/cli/bin/nest.js start",
    "start:dev": "NODE_OPTIONS=\"--no-node-snapshot${NODE_OPTIONS:+ $NODE_OPTIONS}\" node ./node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:debug": "NODE_OPTIONS=\"--no-node-snapshot${NODE_OPTIONS:+ $NODE_OPTIONS}\" node ./node_modules/@nestjs/cli/bin/nest.js start --debug --watch",
    "start:prod": "NODE_OPTIONS=\"--no-node-snapshot${NODE_OPTIONS:+ $NODE_OPTIONS}\" node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:unused": "eslint \"src/**/*.ts\" \"test/**/*.ts\" -c eslint.unused-only.mjs --max-warnings 99999",
    "typeorm": "ts-node ./node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm migration:generate",
    "migration:create": "npm run typeorm migration:create",
    "migration:run": "npm run typeorm migration:run",
    "migration:revert": "npm run typeorm migration:revert",
    "bench:executor": "NODE_OPTIONS=\"--no-node-snapshot --expose-gc\" node scripts/bench-handler-worker-memory.mjs",
    "postinstall": "node -e \"if (!require('fs').existsSync('./node_modules/sharp')) { require('child_process').execSync('yarn add sharp --ignore-engines', {stdio: 'inherit'}) }\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@google-cloud/storage": "^7.19.0",
    "@graphql-tools/schema": "^10.0.31",
    "@liaoliaots/nestjs-redis": "^10.0.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/platform-socket.io": "^11.1.18",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/websockets": "^11.1.18",
    "@socket.io/redis-adapter": "^8.3.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.73.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "graphql": "^16.13.2",
    "graphql-yoga": "^5.21.0",
    "ioredis": "^5.10.1",
    "isolated-vm": "^6.1.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.9",
    "lodash": "^4.18.1",
    "mongodb": "^6.20.0",
    "ms": "3.0.0-canary.202508261828",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "qs": "^6.15.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.1.7",
    "tailwindcss": "^4.2.2",
    "uuid": "^11.1.0",
    "vite": "^7.3.1",
    "vue": "^3.5.32",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.18",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "resolutions": {
    "string-width": "4.2.3",
    "strip-ansi": "6.0.1",
    "cli-table3": "0.6.3",
    "@nestjs/cli": "10.3.2"
  }
}
