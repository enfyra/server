{
  "name": "enfyra-server",
  "version": "2.2.9",
  "description": "Dynamic backend platform that auto-generates REST and GraphQL APIs from database schemas",
  "author": "dothinh115 <dothinh115@gmail.com>",
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "yarn@4.17.0+sha512.c2957de2f9025ab14d63b24d0d8be1f1655810e22c341042c27f7ecd017b180ec12db73d69ac366d71b304ef9f069349ce462de96f04f8f1da317f4f762c95ae",
  "engines": {
    "node": ">=24 <25",
    "yarn": ">=4.17 <5"
  },
  "volta": {
    "node": "24.9.0"
  },
  "scripts": {
    "check:node": "node scripts/check-node-version.js",
    "preinstall": "node scripts/check-node-version.js",
    "prebuild": "node scripts/check-node-version.js",
    "prestart": "node scripts/check-node-version.js",
    "predev": "node scripts/check-node-version.js",
    "predebug": "node scripts/check-node-version.js",
    "pretest:all": "node scripts/check-node-version.js",
    "pretest:watch": "node scripts/check-node-version.js",
    "pretest:ui": "node scripts/check-node-version.js",
    "pretest:e2e": "node scripts/check-node-version.js",
    "generate:mongo-fold": "tsx scripts/generate-mongo-fold-text-search.ts",
    "build": "tsc && yarn generate:mongo-fold && cp -r data dist/",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "NODE_OPTIONS=\"--no-node-snapshot${NODE_OPTIONS:+ $NODE_OPTIONS}\" node dist/main",
    "dev": "DEV_WATCH=1 NODE_OPTIONS=\"--no-node-snapshot${NODE_OPTIONS:+ $NODE_OPTIONS}\" tsx watch --ignore 'dist/**' --ignore 'logs/**' --ignore '/tmp/enfyra-pkg-cache/**' --ignore '/var/folders/**/T/enfyra-pkg-cache/**' --ignore '/private/var/folders/**/T/enfyra-pkg-cache/**' --ignore 'test/**' --ignore 'src/**/*.spec.ts' src/main.ts",
    "debug": "DEV_WATCH=1 NODE_OPTIONS=\"--no-node-snapshot --inspect${NODE_OPTIONS:+ $NODE_OPTIONS}\" tsx watch --ignore 'dist/**' --ignore 'logs/**' --ignore '/tmp/enfyra-pkg-cache/**' --ignore '/var/folders/**/T/enfyra-pkg-cache/**' --ignore '/private/var/folders/**/T/enfyra-pkg-cache/**' --ignore 'test/**' --ignore 'src/**/*.spec.ts' src/main.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:unused": "eslint \"src/**/*.ts\" \"test/**/*.ts\" -c eslint.unused-only.mjs --max-warnings 99999",
    "bench:executor": "NODE_OPTIONS=\"--no-node-snapshot --expose-gc\" node scripts/bench-handler-worker-memory.mjs",
    "test": "node scripts/test-prompt.js",
    "test:all": "NODE_OPTIONS=\"--no-node-snapshot${NODE_OPTIONS:+ $NODE_OPTIONS}\" vitest run",
    "test:watch": "NODE_OPTIONS=\"--no-node-snapshot${NODE_OPTIONS:+ $NODE_OPTIONS}\" vitest",
    "test:ui": "NODE_OPTIONS=\"--no-node-snapshot${NODE_OPTIONS:+ $NODE_OPTIONS}\" vitest --ui",
    "test:e2e:cache-load": "node test/cache-load.e2e.js",
    "test:e2e:metadata-reload": "node test/metadata-reload.e2e.js",
    "test:e2e:flow-engine": "node test/flow-engine.e2e.js",
    "test:e2e:query-builder": "node test/query-builder.e2e.js",
    "test:e2e:realtime-chat-load": "tsx test/realtime-chat-app.e2e.ts",
    "test:e2e:mock": "yarn test:e2e:cache-load && yarn test:e2e:metadata-reload && yarn test:e2e:flow-engine",
    "test:e2e": "yarn test:e2e:mock && yarn test:e2e:query-builder"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/lib-storage": "3.1024.0",
    "@enfyra/kernel": "1.1.26",
    "@envelop/core": "^5.5.1",
    "@envelop/depth-limit": "^7.1.1",
    "@google-cloud/storage": "^7.19.0",
    "@graphql-tools/schema": "^10.0.31",
    "@socket.io/redis-adapter": "^8.3.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "awilix": "^13.0.3",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.73.0",
    "cors": "^2.8.6",
    "cron-parser": "^4.9.0",
    "dotenv": "^17.2.3",
    "eventemitter2": "^6.4.9",
    "express": "^5.0.0",
    "graphql": "^16.13.2",
    "graphql-yoga": "^5.21.0",
    "heic-convert": "^2.1.0",
    "ioredis": "^5.10.1",
    "isolated-vm": "^6.1.2",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.9",
    "mongodb": "^7.1.1",
    "ms": "3.0.0-canary.202508261828",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "qs": "^6.15.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-adapter": "^2.5.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.1.3",
    "uuid": "^11.1.1",
    "vite": "^7.3.1",
    "vue": "^3.5.32",
    "ws": "^8.20.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.2",
    "@types/qs": "^6.15.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^3",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "prompts": "^2.4.2",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.21.0",
    "vitest": "^3.2.6"
  },
  "resolutions": {
    "string-width": "4.2.3",
    "strip-ansi": "6.0.1",
    "cli-table3": "0.6.3",
    "fast-xml-builder": "1.2.0",
    "fast-xml-parser": "5.8.0",
    "flatted": "3.4.2",
    "postcss": "8.5.15",
    "qs": "6.15.2",
    "socket.io-parser": "4.2.6",
    "uuid": "11.1.1",
    "ws": "8.21.0"
  },
  "stableVersion": "2.2.7-patch.1"
}
