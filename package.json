{
  "name": "enfyra-server",
  "version": "2.1.5",
  "description": "Dynamic backend platform that auto-generates REST and GraphQL APIs from database schemas",
  "author": "dothinh115 <dothinh115@gmail.com>",
  "private": false,
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "generate:mongo-fold": "tsx scripts/generate-mongo-fold-text-search.ts",
    "build": "tsc && yarn generate:mongo-fold && cp -r data dist/",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "NODE_OPTIONS=\"--no-node-snapshot${NODE_OPTIONS:+ $NODE_OPTIONS}\" node dist/main",
    "dev": "DEV_WATCH=1 NODE_OPTIONS=\"--no-node-snapshot${NODE_OPTIONS:+ $NODE_OPTIONS}\" tsx watch --ignore 'dist/**' --ignore 'logs/**' --ignore '/tmp/enfyra-pkg-cache/**' --ignore '/var/folders/**/T/enfyra-pkg-cache/**' --ignore '/private/var/folders/**/T/enfyra-pkg-cache/**' --ignore 'test/**' --ignore 'src/**/*.spec.ts' src/main.ts",
    "debug": "DEV_WATCH=1 NODE_OPTIONS=\"--no-node-snapshot --inspect${NODE_OPTIONS:+ $NODE_OPTIONS}\" tsx watch --ignore 'dist/**' --ignore 'logs/**' --ignore '/tmp/enfyra-pkg-cache/**' --ignore '/var/folders/**/T/enfyra-pkg-cache/**' --ignore '/private/var/folders/**/T/enfyra-pkg-cache/**' --ignore 'test/**' --ignore 'src/**/*.spec.ts' src/main.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:unused": "eslint \"src/**/*.ts\" \"test/**/*.ts\" -c eslint.unused-only.mjs --max-warnings 99999",
    "bench:executor": "NODE_OPTIONS=\"--no-node-snapshot --expose-gc\" node scripts/bench-handler-worker-memory.mjs",
    "test": "node scripts/test-prompt.js",
    "test:all": "NODE_OPTIONS=\"--no-node-snapshot${NODE_OPTIONS:+ $NODE_OPTIONS}\" vitest run",
    "test:watch": "NODE_OPTIONS=\"--no-node-snapshot${NODE_OPTIONS:+ $NODE_OPTIONS}\" vitest",
    "test:ui": "NODE_OPTIONS=\"--no-node-snapshot${NODE_OPTIONS:+ $NODE_OPTIONS}\" vitest --ui",
    "test:e2e:cache-load": "node test/cache-load.e2e.js",
    "test:e2e:metadata-reload": "node test/metadata-reload.e2e.js",
    "test:e2e:flow-engine": "node test/flow-engine.e2e.js",
    "test:e2e:query-builder": "node test/query-builder.e2e.js",
    "test:e2e:mock": "yarn test:e2e:cache-load && yarn test:e2e:metadata-reload && yarn test:e2e:flow-engine",
    "test:e2e": "yarn test:e2e:mock && yarn test:e2e:query-builder"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@enfyra/kernel": "1.0.2",
    "@envelop/depth-limit": "^7.1.1",
    "@google-cloud/storage": "^7.19.0",
    "@graphql-tools/schema": "^10.0.31",
    "@socket.io/redis-adapter": "^8.3.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "awilix": "^13.0.3",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.73.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "eventemitter2": "^6.4.9",
    "express": "^5.0.0",
    "graphql": "^16.13.2",
    "graphql-yoga": "^5.21.0",
    "ioredis": "^5.10.1",
    "isolated-vm": "^6.1.2",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.9",
    "mongodb": "^7.1.1",
    "ms": "3.0.0-canary.202508261828",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "qs": "^6.15.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.1.3",
    "uuid": "^11.1.0",
    "vite": "^7.3.1",
    "vue": "^3.5.32",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.2",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^3",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "prompts": "^2.4.2",
    "socket.io-client": "^4.8.3",
    "sqlite3": "^5.1.7",
    "tsx": "^4.21.0",
    "vitest": "^3"
  },
  "resolutions": {
    "string-width": "4.2.3",
    "strip-ansi": "6.0.1",
    "cli-table3": "0.6.3"
  }
}
